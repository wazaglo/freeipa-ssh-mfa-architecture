# Debian common-auth for non-SSH services (sudo, login, etc.)
# This is the STANDARD stack — no OTP order.
# SSH uses its own dedicated PAM service (sshd-otp) with OTP order.
#
# Order: pam_unix.so first (standard), pam_sss.so with use_first_pass

auth	[success=2 default=ignore]	pam_unix.so
auth	[success=1 default=ignore]	pam_sss.so use_first_pass
auth	requisite			pam_deny.so
auth	required			pam_permit.so
auth	optional			pam_cap.so