extends: default

rules:
  line-length:
    max: 200
    level: warning
  truthy:
    allowed-values: ['true', 'false', 'yes', 'no']
  comments:
    min-spaces-from-content: 1
  indentation:
    spaces: 2
    indent-sequences: whatever
  braces:
    min-spaces-inside: 0
    max-spaces-inside: 2
  commas:
    min-spaces-after: 1
    max-spaces-after: 2
