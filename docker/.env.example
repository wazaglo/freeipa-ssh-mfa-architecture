# FreeIPA SSH MFA Docker Test Environment Configuration
# Copy this file to .env before running docker setup

# ------------------------------------------------------------
# IPA Server Configuration
# ------------------------------------------------------------
IPA_SERVER_HOSTNAME=ipa.test.local
IPA_DOMAIN=test.local
IPA_REALM=TEST.LOCAL
IPA_ADMIN_PASSWORD=secure-admin-password-change-this
IPA_DM_PASSWORD=secure-dm-password-change-this
IPA_SERVER_DNS=yes
IPA_SERVER_NTP=yes
IPA_SERVER_IP=172.20.0.10
IPA_SERVER_INSTALL_OPTS=
  --setup-dns
  --no-forwarders
  --auto-reverse
  --mkhomedir
  --unattended

# ------------------------------------------------------------
# SSH Key Generation
# ------------------------------------------------------------
SSH_KEY_BITS=ed25519
SSH_KEY_FILE_PATH=/tmp/ipa_test_ed25519

# ------------------------------------------------------------
# Global Configuration
# ------------------------------------------------------------
LOG_LEVEL=INFO
DRY_RUN=false

# ------------------------------------------------------------
# Network Configuration
# ------------------------------------------------------------
TEST_NET_SUBNET=172.20.0.0/24
TEST_NET_GATEWAY=172.20.0.1
TEST_NET_DNS=8.8.8.8

# ------------------------------------------------------------
# Host Network (additional entries for Docker containers)
# ------------------------------------------------------------
EXTRA_HOSTS=
  \
    ipa.test.local:172.20.0.10, \
    dev01.test.local:172.20.0.11, \
    uat01.test.local:172.20.0.12, \
    prd01.test.local:172.20.0.13

# ------------------------------------------------------------
# User Configuration (for Docker client containers)
# ------------------------------------------------------------
# All test users share the same password for simplicity
TEST_USER_PASSWORD=Passw0rd!

# ------------------------------------------------------------
# Security Settings
# ------------------------------------------------------------
# Allow root login in containers (for testing)
ALLOW_ROOT=true

# Use DNS for hostname resolution
USE_DNS_RESOLUTION=true

# Allow SSH key-based auth
SSH_KEY_AUTH=true

# ------------------------------------------------------------
# Logging and Debugging
# ------------------------------------------------------------
ENABLE_DEBUG_LOGS=true
CAPTURE_CONTAINER_OUTPUT=true

# ------------------------------------------------------------
# Readme
# ------------------------------------------------------------
# Before running this setup, ensure you have:
# 1. Run: docker compose -f docker/docker-compose.yml up -d
# 2. Set .env in docker/ directory with secure passwords
# 3. Run: ./docker/setup.sh

# NOTE: This is a TEST environment with weak passwords.
# Do NOT use this configuration in production.
# All passwords should be changed to strong, unique values.
